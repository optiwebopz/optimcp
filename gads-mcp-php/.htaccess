# File: /gads-mcp-php/.htaccess
# OptiMCP Google Ads MCP PHP — Apache Security Rules
# Version: 1.0.0 | 2026-03-26

# Block direct PHP access except mcp.php and dashboard/
<FilesMatch "^(?!mcp\.php$).*\.php$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Allow dashboard index
<Files "dashboard/index.php">
    Order Allow,Deny
    Allow from all
</Files>

# Block log files, token cache, rate limiter files
<FilesMatch "\.(log|json)$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Block hidden files
<FilesMatch "^\.">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Block config
<Files "config.php">
    Order Deny,Allow
    Deny from all
</Files>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Allow dashboard through
    RewriteRule ^dashboard/?$ dashboard/index.php [L]

    # Route all other requests to mcp.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.*)$ mcp.php [QSA,L]
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "no-referrer"
</IfModule>

Options -Indexes

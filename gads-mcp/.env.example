# File: /gads-mcp/.env
# OptiMCP — Google Ads MCP Server — Environment Config
# Version: 1.0.0
#
# !! COPY TO .env AND FILL IN ALL VALUES !!
# !! NEVER COMMIT .env TO GIT !!

# ── MCP Auth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
MCP_SECRET_TOKEN=REPLACE_WITH_STRONG_RANDOM_TOKEN

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3848

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=YOUR_OAUTH_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_OAUTH_CLIENT_SECRET

# Refresh token — obtained by running: npm run auth
GOOGLE_REFRESH_TOKEN=YOUR_REFRESH_TOKEN

# ── Google Ads API ────────────────────────────────────────────────────────────
# Developer token — from Google Ads Manager Account → Tools → API Centre
GOOGLE_ADS_DEVELOPER_TOKEN=YOUR_DEVELOPER_TOKEN

# Your MCC (Manager) account Customer ID — digits only, no dashes
# e.g. if your MCC ID is 123-456-7890 → enter 1234567890
GOOGLE_ADS_MCC_ID=YOUR_MCC_CUSTOMER_ID

# Google Ads API version — current latest as of March 2026
# Supported versions: v20, v21, v22, v23, v23.1, v23.2
# v23.2 is the latest (released March 25, 2026). v19 and below are sunsetted.
GOOGLE_ADS_API_VERSION=v23.2

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Secure PIN to access the web dashboard at /dashboard
# Set to any strong passphrase — min 12 characters recommended
# Leave blank to disable the dashboard entirely
DASHBOARD_PIN=REPLACE_WITH_STRONG_PASSPHRASE
MCP_RATE_LIMIT=60
MCP_RATE_WINDOW_MS=60000

# ── Logging ───────────────────────────────────────────────────────────────────
MCP_LOG_PATH=./logs/gads-mcp.log
MCP_LOG_LEVEL=info
